<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="jp.co.attendance.attendance_app.mapper.EmployeeMapper">

    <resultMap id="EmployeeAuthResultMap" type="jp.co.attendance.attendance_app.dto.EmployeeAuthDto">
        <id property="id" column="id" />
        <result property="employeeCode" column="employee_code" />
        <result property="password" column="password" />
        <result property="displayName" column="displayName" />
        <result property="roleCode" column="role_code" />
    </resultMap>

    <!-- 【R_001】 ログインユーザー情報の取得 -->
    <select id="findByUsername" resultMap="EmployeeAuthResultMap">
        SELECT
            e.id,
            e.employee_code,
            e.password,
            e.last_name || ' ' || e.first_name AS displayName,
            r.role_code
        FROM
            employees_mst e
        LEFT JOIN
            roles_mst r
            ON e.role_id = r.id
        WHERE
            e.employee_code = #{username}
    </select>

</mapper>
